# ─────────────────────────────────────────────
#  BugFix AI — Environment Variables
#  Copy this file to .env and fill in your key
# ─────────────────────────────────────────────

# NOTE: This project previously used Anthropic. To switch to an OpenAI-compatible
# client (e.g. NVIDIA's integration), comment out the Anthropic key and set the
# following environment variables instead. Do NOT commit real keys to the repo.
# ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Required: OpenAI-compatible base URL for the provider (e.g. NVIDIA Integrate)
# Example: https://integrate.api.nvidia.com/v1
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# Required: API key for the OpenAI-compatible provider (prefix like nvapi-...)
# Set this locally or in your deployment environment; keep it secret.
OPENAI_API_KEY=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

# Optional: Port (default 3000)
PORT=3000

# Optional: Node environment
NODE_ENV=development
